# ═══════════════════════════════════════════════════════════
#  NeighborHealth — .gitignore
#  Covers: Python backend, vanilla JS frontend, macOS, editors
# ═══════════════════════════════════════════════════════════

# ─── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/
sdist/
*.whl
MANIFEST

# Virtual environments
venv/
env/
.env/
.venv/
ENV/
.virtualenv/

# ─── Secrets & Environment ──────────────────────────────────
.env
.env.*
!.env.example
*.env
secrets.json
credentials.json
service_account.json

# ─── ML Models & Large Data Files ───────────────────────────
backend/ml/model/*.pkl
backend/ml/model/*.joblib
backend/ml/model/*.h5
backend/ml/model/*.bin
backend/ml/model/*.onnx
backend/data/*.csv
backend/data/*.json
backend/data/*.parquet
backend/scratch/
*.pkl
*.joblib
*.safetensors

# ─── Uploaded / Temp Files ──────────────────────────────────
backend/temp_health_uploads/
uploads/
*.tmp
*.temp

# ─── Database & Cache ───────────────────────────────────────
*.db
*.sqlite
*.sqlite3
.cache/
*.log
logs/

# ─── macOS ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
Icon?

# ─── Editors & IDEs ─────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─── Node (if any tooling is added) ─────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm/

# ─── Frontend build output (if added later) ─────────────────
frontend/dist/
frontend/build/
frontend/.cache/

# ─── Testing & Coverage ─────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover
*.coveragerc
nosetests.xml
test-results/

# ─── Jupyter ────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Miscellaneous ──────────────────────────────────────────
*.bak
*.orig
*.rej
*.patch
.python-version
Pipfile
Pipfile.lock
poetry.lock

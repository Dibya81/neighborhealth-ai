# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_NAME=NeighborHealth
SECRET_KEY=change-this-to-a-random-32-char-string
ADMIN_API_KEY=change-this-to-another-random-string

# ── Supabase ─────────────────────────────────────────
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Firebase ─────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-adminsdk.json

# ── OpenWeatherMap ───────────────────────────────────
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

# ── AI Assistant (OpenRouter) ────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key

# ── Twilio ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=your_twilio_number

# ── SMTP Email (Gmail) ───────────────────────────────
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-google-app-password

# ── CORS ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000,http://localhost:3001,http://127.0.0.1:3001,http://[::1]:3001,https://your-app.vercel.app

# ── Bengaluru coordinates ────────────────────────────
BENGALURU_LAT=12.9716
BENGALURU_LON=77.5946

# ── Alert threshold ──────────────────────────────────
ALERT_THRESHOLD=70
